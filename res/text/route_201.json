    {
      "id": "Route201_Text_TooSlow",
      "en_US": "Too slow!\r"
    },
    {
      "id": "Route201_Text_LetsGetMovingToProfRowansLab",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: All right!\n",
        "Let’s get moving to Prof. Rowan’s lab.\r"
      ]
    },
    {
      "id": "Route201_Text_TrustMeIveGotAnIdea",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: ...\n",
        "...\r",
        "Trust me on this one.\n",
        "I’ve got an idea!\r"
      ]
    },
    {
      "id": "Route201_Text_ScootOverBeforeWildPokemonCanAppear",
      "en_US": [
        "OK, stick with me!\r"
      ]
    },
    {
      "id": "Route201_Text_HereGoes",
      "en_US": [
        "OK, here goes!\r",
        "On your marks...\r"
      ]
    },
    {
      "id": "Route201_Text_HoldIt",
      "en_US": "{SIZE 200}Hold it!{SIZE 100}\r"
    },
    {
      "id": "Route201_Text_YouTwoDontHaveAnyPokemon",
      "en_US": [
        "Professor: You two don’t seem to have\n",
        "any Pokémon between you?\r"
      ]
    },
    {
      "id": "Route201_Text_RivalEllipsis",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: ...\n",
        "...\r"
      ]
    },
    {
      "id": "Route201_Text_ProfessorEllipsis",
      "en_US": [
        "Professor: ...\n",
        "...\r"
      ]
    },
    {
      "id": "Route201_Text_ThisIsProfRowanIsntIt",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Hey, {STRVAR_1 3, 1, 0}.\n",
        "This old guy...\r"
      ]
    },
    {
      "id": "Route201_Text_HmmWhatToDo",
      "en_US": [
        "Professor: ...\n",
        "...\r"
      ]
    },
    {
      "id": "Route201_Text_YouTrulyLovePokemonDoYou",
      "en_US": [
        "You two.\n",
        "You truly love Pokémon, do you? \r"
      ]
    },
    {
      "id": "Route201_Text_YoureNotMakingAnySense",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Whoa, hold up!\n",
        "You’re not making any sense here!\r"
      ]
    },
    {
      "id": "Route201_Text_IDidntQuiteCatchThat",
      "en_US": [
        "Professor: Er-hem!\r",
        "I didn’t quite catch that, so I will\n",
        "ask you again.\r",
        "You two.\n",
        "You truly love Pokémon, do you?"
      ]
    },
    {
      "id": "Route201_Text_ILovePokemonToo",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Me, too!\n",
        "I love Pokémon, too!\r"
      ]
    },
    {
      "id": "Route201_Text_IWillAskOnceAgain",
      "en_US": [
        "Professor: I will ask you once again.\r",
        "You two.\n",
        "You truly love Pokémon, do you?\r"
      ]
    },
    {
      "id": "Route201_Text_TheAnswerWillNeverChange",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: What?!\n",
        "The answer will never change!\r",
        "We love Pokémon!\r"
      ]
    },
    {
      "id": "Route201_Text_RightPlayer",
      "en_US": "Right, {STRVAR_1 3, 1, 0}?"
    },
    {
      "id": "Route201_Text_ThatJokesGettingOld",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: ...\n",
        "That joke’s getting old!\r"
      ]
    },
    {
      "id": "Route201_Text_ItWorriesMeWhatPeopleWouldDo",
      "en_US": [
        "Professor: ...A pair of reckless kids\n",
        "who foolishly try to enter tall grass\f",
        "without Pokémon of their own...?\r"
      ]
    },
    {
      "id": "Route201_Text_GiveAPokemonToMyFriendHere",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: ...Uh...\n",
        "Well, I, uh...\r",
        "...\n",
        "...\r"
      ]
    },
    {
      "id": "Route201_Text_IWillEntrustYouWithPokemon",
      "en_US": [
        "Professor: !\r",
        "How big of you...\r",
        "Very well, then!\n",
        "I will entrust you two with Pokémon!\r"
      ]
    },
    {
      "id": "Route201_Text_DawnYouLeftYourBriefcaseAtTheLake",
      "en_US": [
        "Dawn: Professor Rowan.\r",
        "You left your briefcase at the lake!\r"
      ]
    },
    {
      "id": "Route201_Text_OhIsSomethingWrongHere",
      "en_US": [
        "Oh?\n",
        "Is something wrong here?\r"
      ]
    },
    {
      "id": "Route201_Text_LucasYouLeftYourBriefcaseAtTheLake",
      "en_US": [
        "Lucas: Professor Rowan!\r",
        "You left your briefcase behind at\n",
        "the lake.\r"
      ]
    },
    {
      "id": "Route201_Text_IsSomethingWrongHere",
      "en_US": "Is something wrong here?\r"
    },
    {
      "id": "Route201_Text_ThereItIsNiceWorkDawn",
      "en_US": [
        "Rowan: Ah! There it is!\n",
        "Dawn, nice work.\r",
        "What I was about to do was to entrust\n",
        "these two with their own Pokémon.\r"
      ]
    },
    {
      "id": "Route201_Text_ThereItIsNiceWorkLucas",
      "en_US": [
        "Rowan: Ah! There it is!\n",
        "Lucas, nice work.\r"
      ]
    },
    {
      "id": "Route201_Text_DawnThosePokemonAreHardToReplace",
      "en_US": [
        "Dawn: Pardon?!\r"
      ]
    },
    {
      "id": "Route201_Text_LucasThosePokemonAreCrucial",
      "en_US": [
        "Lucas: Wha...?!\r"
      ]
    },
    {
      "id": "Route201_Text_PeopleShouldMeetPokemon",
      "en_US": [
        "Rowan: Hm!\r"
      ]
    },
    {
      "id": "Route201_Text_GoOnChooseAPokemon",
      "en_US": [
        "Go on! Open the briefcase and choose\n",
        "a Pokémon!\r"
      ]
    },
    {
      "id": "Route201_Text_RowanGoOnChooseAPokemon",
      "en_US": [
        "Rowan: Go on! Open the briefcase and\n",
        "choose a Pokémon!"
      ]
    },
    {
      "id": "Route201_Text_ICantBelieveIt",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Really?!\n"
      ]
    },
    {
      "id": "Route201_Text_YouCanChooseFirst",
      "en_US": [
        "Hey, {STRVAR_1 3, 1, 0}.\n",
        "You can choose first.\r"
      ]
    },
    {
      "id": "Route201_Text_PickAPokemon",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: What’s up with you?\n",
        "Open the briefcase and pick a Pokémon!\r"
      ]
    },
    {
      "id": "Route201_Text_ImPickingThisStarter",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Then, I choose you!\n",
        "I’m picking this {STRVAR_1 0, 2, 0}!\r"
      ]
    },
    {
      "id": "Route201_Text_IHopeYoullDoWellTogether",
      "en_US": [
        "Rowan: Very well! Both of you have\n",
        "chosen a good Pokémon, it seems.\r"
      ]
    },
    {
      "id": "Route201_Text_ComeSeeMeInSandgemTown",
      "en_US": [
        "If you have any trouble, come see me\n",
        "at my lab in Sandgem Town.\r",
        "And now, we’ll be on our way.\r"
      ]
    },
    {
      "id": "Route201_Text_DawnWaitForMe",
      "en_US": [
        "Dawn: Professor!\n",
        "Wait for me, please!\r"
      ]
    },
    {
      "id": "Route201_Text_DawnPleaseLetMePass",
      "en_US": [
        "Let me pass.\r"
      ]
    },
    {
      "id": "Route201_Text_LucasWaitForMe",
      "en_US": [
        "Lucas: Professor!\n",
        "Wait for me!\r"
      ]
    },
    {
      "id": "Route201_Text_LucasSorryFolks",
      "en_US": "Uh, sorry, folks.\r"
    },
    {
      "id": "Route201_Text_ProfRowansReallyNice",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: How do you like that?\n"
      ]
    },
    {
      "id": "Route201_Text_OnlyOneThingToDo",
      "en_US": [
        "Are you up for this?\r"
      ]
    },
    {
      "id": "Route201_Text_DontBeThatWay",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: What’s with that attitude?\n",
        "Don’t be that way!\r"
      ]
    },
    {
      "id": "Route201_Text_Dummy6",
      "garbage": 41
    },
    {
      "id": "Route201_Text_IChallengeYouToABattle",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: I’ve always wanted to\n",
        "I challenge you to a battle!\r"
      ]
    },
    {
      "id": "Route201_Text_WhewLetsGoHome",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Whew!\n",
        "See ya, {STRVAR_1 3, 1, 0}!\r"
      ]
    },
    {
      "id": "Route201_Text_IWonLetsGoHome",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Aha...\n",
        "Ahaha... I won? I won!\r"
      ]
    },
    {
      "id": "Route201_Text_LetsCatchThatLegendaryPokemon",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Too slow!\n",
        "{STRVAR_1 3, 1, 0}, I’m sick of waiting!\r"
      ]
    },
    {
      "id": "Route201_Text_TogetherWeveGotNothingToFear",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Me and you together,\n",
        "we’ve got nothing to fear!"
      ]
    },
    {
      "id": "Route201_Text_TheLakesNotThatWay",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Heheh, {STRVAR_1 3, 1, 0}.\n",
        "The lake’s not that way!\r"
      ]
    },
    {
      "id": "Route201_Text_ISaidTheLakesNotThatWay",
      "en_US": [
        "{STRVAR_1 3, 0, 0}: Hey, {STRVAR_1 3, 1, 0}!\n",
        "I said, the lake’s not that way!\r"
      ]
    },
    {
      "id": "Route201_Text_WildPokemonLurkInTallGrass",
      "en_US": [
        "Wild Pokémon lurk in tall grass. They\n",
        "can come bursting out at any time.\r"
      ]
    },
    {
      "id": "Route201_Text_HereAPotionAsAFreeSample",
      "en_US": [
        "Hi!\n",
        "I work at a Pokémon Mart.\r",
        "Here, let me give you a Potion as\n",
        "a free sample. First one’s free!\r"
      ]
    },
    {
      "id": "Route201_Text_YouCanFindMartsInCitiesAndMajorTowns",
      "en_US": [
        "You can find a Pokémon Mart in cities\n",
        "and most major towns."
      ]
    },
    {
      "id": "Route201_Text_ThatLedgeIsOneWay",
      "en_US": [
        "That ledge is one way. Jump down\n",
        "for a shortcut to Twinleaf Town!"
      ]
    },
    {
      "id": "Route201_Text_IfYourPokemonsHPIsLowGoHome",
      "en_US": [
        "If your Pokémon’s health--that’s its\n",
        "HP--is getting low, you should go\f",
        "home and get some rest."
      ]
    },
    {
      "id": "Route201_Text_IfYourPokemonsHPIsLowGoToAPokemonCenter",
      "en_US": [
        "If your Pokémon’s health--that’s its\n",
        "HP--is getting low, you should go\f",
        "to a Pokémon Center!"
      ]
    },
    {
      "id": "Route201_Text_Rt201TwinleafTown",
      "en_US": [
        "Rt. 201\n",
        "Twinleaf Town"
      ]
    },
    {
      "id": "Route201_Text_Rt201SandgemTown",
      "en_US": [
        "Rt. 201\n",
        "Sandgem Town"
      ]
    },
    {
      "id": "Route201_Text_TrainerTipsTalkToAnyone",
      "en_US": [
        "Trainer Tips!\r",
        "Don’t be shy! Talk to anyone and\n",
        "everyone you happen to see.\r"
      ]
    }
  ]
